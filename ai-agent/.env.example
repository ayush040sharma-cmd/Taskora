# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Taskora backend (Express)
TASKORA_API_URL=http://localhost:3001/api
TASKORA_ADMIN_TOKEN=your-admin-jwt-token

# Agent DB (can reuse Taskora's Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/kanban_db

# Agent settings
AGENT_PORT=8000
AGENT_ENV=development
MAX_TOOL_ITERATIONS=10
MEMORY_TTL_SECONDS=3600

# GitHub integration (Jarvis multi-agent)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=Taskora

# Security
JWT_SECRET=your-jwt-secret-key

# Orchestrator
DRY_RUN=false
AUDIT_SCHEDULE_HOUR=3
